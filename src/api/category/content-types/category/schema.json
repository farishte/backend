{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Categories used to group Institutional Eye articles."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "institutional_eyes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::institutional-eye.institutional-eye",
      "mappedBy": "category"
    }
  }
}
